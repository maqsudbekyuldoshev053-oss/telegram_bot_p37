@dp.message(CommandStart())
async def start_handler(message: Message, bot: Bot):
    await message.answer('Xush kelibsiz')
    await dp.storage.redis.sadd("users", message.from_user.id)
    buttons = []

    for module in MODULES.keys():
        buttons.append(
            [
                InlineKeyboardButton(text=module, callback_data=f"module:{module}")
            ]
        )
    ikm = InlineKeyboardMarkup(inline_keyboard=buttons)

    await message.answer("Modullardan birini tanlang:", reply_markup=ikm)


@dp.callback_query(lambda c: c.data.startswith("module:"))
async def module_handler(callback: types.CallbackQuery):
    module_name = callback.data.split(":")[1]

    dars_buttons = []
    for dars_name in MODULES[module_name].keys():
        dars_buttons.append(
            [
                InlineKeyboardButton(
                    text=dars_name,
                    callback_data=f"dars:{module_name}:{dars_name}"
                )
            ]
        )
    dars_buttons.append(
        [
            InlineKeyboardButton(
                text="⬅️ Orqaga",
                callback_data="back_to_modules"
            )
        ]
    )

    ikm = InlineKeyboardMarkup(inline_keyboard=dars_buttons)

    await callback.message.edit_text(
        f"{module_name} darslari:",
        reply_markup=ikm
    )


@dp.callback_query(lambda c: c.data.startswith("dars:"))
async def lesson_handler(callback: types.CallbackQuery):
    _, module_name, dars_name = callback.data.split(":")
    url = MODULES[module_name][dars_name]

    await dp.storage.redis.incr(f"lesson:{module_name}:{dars_name}")

    async with aiohttp.ClientSession() as session:
        async with session.get(url) as resp:
            if resp.status != 200:
                await callback.message.answer("Faylni yuklab bo'lmadi")
                return
            file_data = await resp.read()
            file_name = url.split("/")[-1]

    with tempfile.NamedTemporaryFile(delete=False, suffix=file_name) as tmp_file:
        tmp_file.write(file_data)
        tmp_path = tmp_file.name

    document = FSInputFile(path=tmp_path, filename=file_name)
    await callback.message.answer_document(document=document)

    os.remove(tmp_path)

    back_keyboard = InlineKeyboardMarkup(
        inline_keyboard=[
            [
                InlineKeyboardButton(
                    text="⬅️ Orqaga",
                    callback_data=f"module:{module_name}"
                )
            ]
        ]
    )
    await callback.message.answer("Darslar:", reply_markup=back_keyboard)

